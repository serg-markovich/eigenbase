# eigenbase — copy to .env and fill in your values
# .env is in .gitignore — NEVER committed

GIT_USER_NAME="Serg Markovich"
GIT_USER_EMAIL="me@serg-markovich.de"
GITHUB_USERNAME="serg-markovich"

# Azure — needed for azure_enterprise + terraform_backend roles
AZURE_TENANT_ID=""
AZURE_SUBSCRIPTION_ID=""
AZURE_RESOURCE_GROUP="rg-eigenstack"
AZURE_STORAGE_ACCOUNT="tfstateeigenstack"

# Ansible Vault (optional)
# ANSIBLE_VAULT_PASSWORD_FILE="~/.vault_pass"
