# eigenbase managed — edit roles/dotfiles/templates/zshrc.j2 to customize

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="{{ base_ohmyzsh_theme | default('robbyrussell') }}"

plugins=(git docker kubectl helm terraform direnv fzf z)

source $ZSH/oh-my-zsh.sh

# Aliases
alias k='kubectl'
alias kx='kubectx'
alias kn='kubens'
alias tf='terraform'
alias dc='docker compose'
alias ll='ls -la'
alias cat='bat --style=plain'

# direnv hook
eval "$(direnv hook zsh)"

# fzf
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Load eigenbase .env
[ -f "$HOME/eigenbase/.env" ] && source "$HOME/eigenbase/.env"
